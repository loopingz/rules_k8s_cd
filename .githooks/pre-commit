#!/usr/bin/env bash
set -euo pipefail

# Get staged .bzl, BUILD, BUILD.bazel, WORKSPACE, MODULE.bazel files
STARLARK_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(bzl)$|^BUILD$|^BUILD\.bazel$|/BUILD$|/BUILD\.bazel$|^WORKSPACE$|^MODULE\.bazel$' || true)

if [ -z "$STARLARK_FILES" ]; then
    exit 0
fi

echo "Running buildifier on staged Starlark files..."

# Run buildifier in check mode first
if ! bazel run @buildifier//:buildifier -- --mode=check $STARLARK_FILES 2>/dev/null; then
    echo "Buildifier found formatting issues. Fixing and re-staging..."
    bazel run @buildifier//:buildifier -- $STARLARK_FILES
    echo "$STARLARK_FILES" | xargs git add
    echo "Files reformatted and staged."
fi

# Regenerate stardoc if any rule .bzl files changed
RULE_FILES=$(echo "$STARLARK_FILES" | grep -E '^lib/[^/]+\.bzl$' || true)

if [ -n "$RULE_FILES" ]; then
    echo "Regenerating stardoc API docs..."
    bazel build //docs/... 2>/dev/null
    cp bazel-bin/docs/*.md docs/ 2>/dev/null || true
    git add docs/*.md 2>/dev/null || true
    echo "Docs regenerated and staged."
fi
